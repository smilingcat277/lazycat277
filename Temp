        c = 0;
		while ((c = getchar())!= '\n' && c!= EOF){
		}
		
        while(!(choice >=1 && choice <= 6)){
        	
        	printf("!Enter a valid index from the options!: ");
        	scanf("%d", &choice);
        	
        	c = 0;
			while ((c = getchar())!= '\n' && c!= EOF){
			}
		}

        switch (choice) {
            case 1:
                addTask();
                saveTasks(1);
                break;
            case 2:
                updateTaskStatus();
